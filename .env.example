# Public site URL (used for canonical, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://amazingdealstracker.pages.dev

# Amazon affiliate tag — appended to all Amazon links
NEXT_PUBLIC_AMAZON_TAG=azdealzs-21

# Server-only secret — HMAC key for request signing (Phase 4)
API_SIGNING_SECRET=change-me-to-a-64-char-random-string

# Cloudflare Turnstile (Phase 4) — leave blank to skip during dev
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Turso DB (Phase 5)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
